/-
If the derivative of a function is never zero on a convex set, then it is either always positive or always negative.
-/
lemma deriv_ne_zero_imp_pos_or_neg
  {f : ℝ → ℝ} {S : Set ℝ} (hS : Convex ℝ S)
  (hderiv : ∀ x ∈ S, DifferentiableAt ℝ f x)
  (hne : ∀ x ∈ S, deriv f x ≠ 0) :
  (∀ x ∈ S, 0 < deriv f x) ∨ (∀ x ∈ S, deriv f x < 0) := by
    -- By definition of convexity, the image of $S$ under the derivative function is also convex.
    have h_image_convex : Convex ℝ (Set.image (deriv f) S) := by
      exact Convex.image_deriv hS hderiv;
    contrapose! hne;
    exact h_image_convex.ordConnected.out ( Set.mem_image_of_mem _ hne.1.choose_spec.1 ) ( Set.mem_image_of_mem _ hne.2.choose_spec.1 ) ⟨ hne.1.choose_spec.2, hne.2.choose_spec.2 ⟩

/-
If a continuous function has a non-zero derivative on $(b, \infty)$, it is strictly monotone on $[b, \infty)$.
-/
lemma deriv_ne_zero_imp_strict_mono_or_anti
  {f f' : ℝ → ℝ} {b : ℝ}
  (hcont : ContinuousOn f (Set.Ici b))
  (hderiv : ∀ x ∈ Set.Ioi b, HasDerivAt f (f' x) x)
  (hne : ∀ x ∈ Set.Ioi b, f' x ≠ 0) :
  StrictMonoOn f (Set.Ici b) ∨ StrictAntiOn f (Set.Ici b) := by
    -- Since `Set.Ioi b` is convex, `interior (Set.Ici b) = Set.Ioi b`.
    have h_convex : Convex ℝ (Set.Ici b) := by
      exact convex_Ici b;
    -- By `deriv_ne_zero_imp_pos_or_neg`, `deriv f` is either always positive or always negative on `Set.Ioi b`.
    obtain (hpos | hneg) : (∀ x ∈ Set.Ioi b, 0 < deriv f x) ∨ (∀ x ∈ Set.Ioi b, deriv f x < 0) := by
      apply deriv_ne_zero_imp_pos_or_neg;
      · exact convex_Ioi b;
      · exact fun x hx => HasDerivAt.differentiableAt ( hderiv x hx );
      · exact fun x hx => by rw [ hderiv x hx |> HasDerivAt.deriv ] ; exact hne x hx;
    · exact Or.inl <| strictMonoOn_of_deriv_pos h_convex ( by aesop ) ( by aesop );
    · -- If `deriv f` is always negative, consider `g = -f`. `deriv g = - deriv f > 0`.
      have h_neg : StrictMonoOn (fun x => -f x) (Set.Ici b) := by
        apply_rules [ strictMonoOn_of_deriv_pos ];
        · exact hcont.neg;
        · aesop;
      exact Or.inr fun x hx y hy hxy => neg_lt_neg_iff.mp ( h_neg hx hy hxy )

